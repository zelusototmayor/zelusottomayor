<% content_for :title, "Workflow Automation Systems | Ze Lu Sottomayor" %>
<% content_for :meta_description, "I design and implement workflow automation systems for repetitive operational processes, with clear logic, documentation, and handover." %>
<% content_for :body_class, "automation-page" %>
<% content_for :head do %>
  <script type="application/ld+json">
    <%= {
      "@context" => "https://schema.org",
      "@type" => "FAQPage",
      "mainEntity" => [
        {
          "@type" => "Question",
          "name" => "How quickly can workflow automation systems be implemented?",
          "acceptedAnswer" => {
            "@type" => "Answer",
            "text" => "Initial implementations can usually be shipped in 2–4 weeks, depending on integration complexity and access to existing tools."
          }
        },
        {
          "@type" => "Question",
          "name" => "What tools can you integrate for automation?",
          "acceptedAnswer" => {
            "@type" => "Answer",
            "text" => "I integrate common CRM, project management, ecommerce, reporting tools, and custom APIs when required."
          }
        },
        {
          "@type" => "Question",
          "name" => "Do you provide documentation and handover?",
          "acceptedAnswer" => {
            "@type" => "Answer",
            "text" => "Yes. Every system includes workflow logic documentation and handover guidance so your team can operate it confidently."
          }
        },
        {
          "@type" => "Question",
          "name" => "Can you build AI-assisted workflow automation?",
          "acceptedAnswer" => {
            "@type" => "Answer",
            "text" => "Yes. I can add AI-assisted classification, routing, and draft-generation where useful, while keeping workflows observable and maintainable."
          }
        }
      ]
    }.to_json.html_safe %>
  </script>
<% end %>

<section class="auto-hero">
  <div class="auto-hero__bg">
    <div class="auto-hero__orb auto-hero__orb--1"></div>
    <div class="auto-hero__orb auto-hero__orb--2"></div>
  </div>
  <div class="container container--narrow">
    <span class="auto-badge">Workflow Automation</span>
    <h1 class="auto-hero__headline">
      Workflow automation systems for cleaner operations.
    </h1>
    <p class="auto-hero__sub">
      I design and implement automation systems for repetitive operational workflows,
      with clear logic, documentation, and handover.
    </p>
    <div class="auto-hero__cta">
      <%= link_to book_call_path, class: "cta-button cta-button--primary cta-button--large" do %>
        <span>Book an operations audit</span>
      <% end %>
      <p class="auto-hero__cta-note">20-minute call · Scoped around your current workflow</p>
    </div>
  </div>
</section>

<section class="auto-pain section-padding">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Where teams usually get stuck</h2>
      <p class="section-subtitle">Common operational friction points before workflow automation is implemented.</p>
    </div>

    <div class="auto-pain__grid">
      <div class="auto-pain__card">
        <h3 class="auto-pain__title">Repetitive manual steps</h3>
        <p class="auto-pain__text">Data is copied between tools multiple times, creating delays and avoidable errors.</p>
      </div>

      <div class="auto-pain__card">
        <h3 class="auto-pain__title">Inconsistent handoffs</h3>
        <p class="auto-pain__text">Ownership drops between teams and tasks get delayed when process logic is unclear.</p>
      </div>

      <div class="auto-pain__card">
        <h3 class="auto-pain__title">Fragmented reporting flow</h3>
        <p class="auto-pain__text">Reporting and status updates consume execution time due to disconnected tools and manual compilation.</p>
      </div>

      <div class="auto-pain__card">
        <h3 class="auto-pain__title">No fallback logic</h3>
        <p class="auto-pain__text">When automations fail, there is often no clear recovery path documented for the team.</p>
      </div>
    </div>
  </div>
</section>

<section class="auto-services section-padding bg-gradient">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">How I implement automation systems</h2>
      <p class="section-subtitle">A practical implementation sequence focused on reliability and handover.</p>
    </div>

    <div class="auto-services__grid">
      <div class="auto-services__card">
        <div class="auto-services__number">01</div>
        <h3 class="auto-services__title">Workflow mapping</h3>
        <p class="auto-services__text">Map current process, actors, and bottlenecks before building any automation logic.</p>
      </div>

      <div class="auto-services__card">
        <div class="auto-services__number">02</div>
        <h3 class="auto-services__title">Scope + logic definition</h3>
        <p class="auto-services__text">Define triggers, actions, ownership, and expected behavior for each automated step.</p>
      </div>

      <div class="auto-services__card">
        <div class="auto-services__number">03</div>
        <h3 class="auto-services__title">Build + QA</h3>
        <p class="auto-services__text">Implement integrations and validate with error handling and fallback rules.</p>
      </div>

      <div class="auto-services__card">
        <div class="auto-services__number">04</div>
        <h3 class="auto-services__title">Documentation + handover</h3>
        <p class="auto-services__text">Deliver process documentation and transition plan so your team can operate the system confidently.</p>
      </div>
    </div>
  </div>
</section>

<section class="auto-process section-padding">
  <div class="container container--narrow">
    <div class="section-header">
      <h2 class="section-title">What you get</h2>
      <p class="section-subtitle">Delivery artifacts focused on clarity and operational continuity.</p>
    </div>

    <div class="auto-process__steps">
      <div class="auto-process__step">
        <div class="auto-process__step-num">1</div>
        <div class="auto-process__step-body">
          <h3 class="auto-process__step-title">Workflow map</h3>
          <p class="auto-process__step-text">Current-state and target-state process mapping for the selected workflow.</p>
          <span class="auto-process__step-tag">Process visibility</span>
        </div>
      </div>

      <div class="auto-process__connector"></div>

      <div class="auto-process__step">
        <div class="auto-process__step-num">2</div>
        <div class="auto-process__step-body">
          <h3 class="auto-process__step-title">Automation implementation</h3>
          <p class="auto-process__step-text">Integrated automation logic, tested with failure handling and clear ownership paths.</p>
          <span class="auto-process__step-tag">Implemented system</span>
        </div>
      </div>

      <div class="auto-process__connector"></div>

      <div class="auto-process__step">
        <div class="auto-process__step-num">3</div>
        <div class="auto-process__step-body">
          <h3 class="auto-process__step-title">Handover package</h3>
          <p class="auto-process__step-text">Documentation and operating guidance so the workflow remains maintainable after delivery.</p>
          <span class="auto-process__step-tag">Operational continuity</span>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="auto-faq section-padding">
  <div class="container container--narrow">
    <div class="section-header">
      <h2 class="section-title">Workflow automation FAQ</h2>
      <p class="section-subtitle">Common questions before an operations audit.</p>
    </div>

    <div class="auto-services__grid">
      <div class="auto-services__card">
        <h3 class="auto-services__title">How fast can implementation start?</h3>
        <p class="auto-services__text">Once access and scope are clear, implementation can begin immediately with a staged rollout.</p>
      </div>
      <div class="auto-services__card">
        <h3 class="auto-services__title">Do you use our existing tools?</h3>
        <p class="auto-services__text">Yes. The default approach is to integrate your current stack first and only replace tools when necessary.</p>
      </div>
      <div class="auto-services__card">
        <h3 class="auto-services__title">Can this include AI features?</h3>
        <p class="auto-services__text">Yes, where useful. AI is added as a component inside a reliable process, not as a black-box replacement.</p>
      </div>
      <div class="auto-services__card">
        <h3 class="auto-services__title">What happens after delivery?</h3>
        <p class="auto-services__text">You receive documentation, operating guidance, and a clear structure for future iterations.</p>
      </div>
    </div>
  </div>
</section>

<%= render 'shared/cta_section',
    headline: "Book an operations audit.",
    subheadline: "We’ll review one workflow and map a practical automation system for your team.",
    button_text: "Book an operations audit",
    button_url: book_call_path,
    secondary_text: "Or send a message",
    secondary_url: contact_path,
    extra_info: "Focused review. Clear next steps." %>
