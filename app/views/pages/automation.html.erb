<% content_for :title, "Automation Services - Ze Lu Sottomayor" %>
<% content_for :meta_description, "Custom workflow automation for businesses. I connect your tools, eliminate manual data work, and build systems that run without you. Based in Lisbon, working remotely." %>
<% content_for :body_class, "automation-page" %>
<% content_for :head do %>
  <script type="application/ld+json">
    <%= {
      "@context" => "https://schema.org",
      "@type" => "FAQPage",
      "mainEntity" => [
        {
          "@type" => "Question",
          "name" => "How quickly can workflow automation systems be implemented?",
          "acceptedAnswer" => {
            "@type" => "Answer",
            "text" => "Initial implementations can usually be shipped in 2–4 weeks, depending on integration complexity and access to existing tools."
          }
        },
        {
          "@type" => "Question",
          "name" => "What tools can you integrate for automation?",
          "acceptedAnswer" => {
            "@type" => "Answer",
            "text" => "I integrate common CRM, project management, ecommerce, reporting tools, and custom APIs when required."
          }
        },
        {
          "@type" => "Question",
          "name" => "Do you provide documentation and handover?",
          "acceptedAnswer" => {
            "@type" => "Answer",
            "text" => "Yes. Every system includes workflow logic documentation and handover guidance so your team can operate it confidently."
          }
        },
        {
          "@type" => "Question",
          "name" => "Can you build AI-assisted workflow automation?",
          "acceptedAnswer" => {
            "@type" => "Answer",
            "text" => "Yes. I can add AI-assisted classification, routing, and draft-generation where useful, while keeping workflows observable and maintainable."
          }
        }
      ]
    }.to_json.html_safe %>
  </script>
<% end %>

<%# ======================================
    HERO
    ====================================== %>
<section class="auto-hero">
  <div class="auto-hero__bg">
    <div class="auto-hero__orb auto-hero__orb--1"></div>
    <div class="auto-hero__orb auto-hero__orb--2"></div>
  </div>
  <div class="container container--narrow">
    <span class="auto-badge">Automation Services</span>
    <h1 class="auto-hero__headline">
      I build automations that <span class="auto-highlight">eliminate your manual work</span>
    </h1>
    <p class="auto-hero__sub">
      Custom workflow automation for founders and small teams.
      I connect your tools, cut the repetitive tasks, and build systems that run without you.
    </p>
    <div class="auto-hero__cta">
      <%= link_to book_call_path, class: "cta-button cta-button--primary cta-button--large" do %>
        <span>Book a call</span>
      <% end %>
      <p class="auto-hero__cta-note">30-minute call · No obligation · Let's see what can be automated</p>
    </div>
  </div>
</section>

<%# ======================================
    PAIN POINTS
    ====================================== %>
<section class="auto-pain section-padding">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Sound familiar?</h2>
      <p class="section-subtitle">These are the kinds of problems I solve.</p>
    </div>

    <div class="auto-pain__grid">
      <div class="auto-pain__card">
        <div class="auto-pain__icon">⏳</div>
        <h3 class="auto-pain__title">Repetitive data entry</h3>
        <p class="auto-pain__text">You're copying data between tools — CRM to spreadsheet, spreadsheet to invoice — over and over, every day.</p>
      </div>

      <div class="auto-pain__card">
        <div class="auto-pain__icon">📊</div>
        <h3 class="auto-pain__title">Reporting takes all day</h3>
        <p class="auto-pain__text">Every Monday is lost to pulling numbers, building reports, and formatting slides instead of doing actual work.</p>
      </div>

      <div class="auto-pain__card">
        <div class="auto-pain__icon">💸</div>
        <h3 class="auto-pain__title">Too many tools, still manual</h3>
        <p class="auto-pain__text">You're paying for multiple SaaS tools but still doing things manually because nothing talks to each other.</p>
      </div>

      <div class="auto-pain__card">
        <div class="auto-pain__icon">🚨</div>
        <h3 class="auto-pain__title">Small mistakes add up</h3>
        <p class="auto-pain__text">Wrong numbers in a report, missed follow-ups, duplicate entries — manual processes break when things get busy.</p>
      </div>
    </div>
  </div>
</section>

<%# ======================================
    WHAT I BUILD
    ====================================== %>
<section class="auto-services section-padding bg-gradient">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">What I build</h2>
      <p class="section-subtitle">Custom systems built for your exact workflow — not templates.</p>
    </div>

    <div class="auto-services__grid">
      <div class="auto-services__card">
        <div class="auto-services__number">01</div>
        <h3 class="auto-services__title">Custom Workflow Automation</h3>
        <p class="auto-services__text">I map your actual operations and build automations that fit how you already work — not force you into someone else's template.</p>
      </div>

      <div class="auto-services__card">
        <div class="auto-services__number">02</div>
        <h3 class="auto-services__title">AI-Powered Workflows</h3>
        <p class="auto-services__text">Intelligent routing, categorization, and responses built into your workflows — so you handle exceptions, not routine.</p>
      </div>

      <div class="auto-services__card">
        <div class="auto-services__number">03</div>
        <h3 class="auto-services__title">Tool Integration</h3>
        <p class="auto-services__text">CRM, reporting, billing, scheduling, client onboarding — I connect your tools so data flows automatically between them.</p>
      </div>

      <div class="auto-services__card">
        <div class="auto-services__number">04</div>
        <h3 class="auto-services__title">Ongoing Support</h3>
        <p class="auto-services__text">I don't just build and disappear. I monitor, optimize, and support the systems I build to keep everything running smoothly.</p>
      </div>
    </div>
  </div>
</section>

<%# ======================================
    SEE IT IN ACTION
    ====================================== %>
<section class="auto-demo section-padding">
  <div class="container container--narrow">
    <div class="section-header">
      <h2 class="section-title">See it in action</h2>
      <p class="section-subtitle">Here's a real system I built and use every day.</p>
    </div>

    <div class="auto-services__card" style="text-align: center;">
      <h3 class="auto-services__title">Outbound Lead System</h3>
      <p class="auto-services__text">An end-to-end outbound system that sources B2B leads, enriches contact data, and sends personalized email sequences — all automated. The CRM dashboard below is where I manage the entire pipeline.</p>
      <div style="margin-top: 1.5rem;">
        <%= link_to "https://leads.zelusottomayor.com", target: "_blank", rel: "noopener", class: "cta-button cta-button--primary" do %>
          <span>View the dashboard</span>
          <span class="button-arrow">&rarr;</span>
        <% end %>
      </div>
    </div>
  </div>
</section>

<%# ======================================
    HOW IT WORKS
    ====================================== %>
<section class="auto-process section-padding">
  <div class="container container--narrow">
    <div class="section-header">
      <h2 class="section-title">How it works</h2>
      <p class="section-subtitle">From first call to a working system — straightforward and clear.</p>
    </div>

    <div class="auto-process__steps">
      <div class="auto-process__step">
        <div class="auto-process__step-num">1</div>
        <div class="auto-process__step-body">
          <h3 class="auto-process__step-title">Workflow Review</h3>
          <p class="auto-process__step-text">We talk through your current process. I identify what's manual, repetitive, and worth automating — and what's not.</p>
          <span class="auto-process__step-tag">30-min call · Free · No obligation</span>
        </div>
      </div>

      <div class="auto-process__connector"></div>

      <div class="auto-process__step">
        <div class="auto-process__step-num">2</div>
        <div class="auto-process__step-body">
          <h3 class="auto-process__step-title">Build & Test</h3>
          <p class="auto-process__step-text">I build the automation around your actual workflow and test it with your real data. You see progress along the way and give feedback.</p>
          <span class="auto-process__step-tag">Built for your exact processes</span>
        </div>
      </div>

      <div class="auto-process__connector"></div>

      <div class="auto-process__step">
        <div class="auto-process__step-num">3</div>
        <div class="auto-process__step-body">
          <h3 class="auto-process__step-title">Handoff & Support</h3>
          <p class="auto-process__step-text">Once it's working, I hand it off with documentation. If something breaks or needs adjusting, I fix it. Simple as that.</p>
          <span class="auto-process__step-tag">Documentation + ongoing support</span>
        </div>
      </div>
    </div>
  </div>
</section>

<%# ======================================
    WHO THIS IS FOR
    ====================================== %>
<section class="auto-proof section-padding bg-gradient">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">Who I work with</h2>
      <p class="section-subtitle">Founders and small teams who are tired of manual busywork.</p>
    </div>

    <div class="auto-proof__audiences">
      <div class="auto-proof__audience">
        <h3>Marketing Agencies</h3>
        <p>Automate client reporting, campaign tracking, and internal workflows so your team focuses on strategy — not spreadsheets.</p>
      </div>
      <div class="auto-proof__audience">
        <h3>E-Commerce Brands</h3>
        <p>Sync inventory, automate order processing, and streamline customer communication across channels.</p>
      </div>
      <div class="auto-proof__audience">
        <h3>Service Businesses</h3>
        <p>Automate scheduling, invoicing, and client onboarding — eliminate the admin that slows down growth.</p>
      </div>
    </div>
  </div>
</section>

<%# ======================================
    FINAL CTA
    ====================================== %>
<%= render 'shared/cta_section',
    headline: "Let's see what can be automated.",
    subheadline: "Book a call and I'll walk through your workflow with you. No pitch, just practical advice on what's worth automating.",
    button_text: "Book a call",
    button_url: book_call_path,
    secondary_text: "Or send me a message",
    secondary_url: contact_path,
    extra_info: "I typically respond within 24 hours." %>
