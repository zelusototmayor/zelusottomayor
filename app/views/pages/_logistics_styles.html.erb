    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    color: var(--color-accent);
  }

  /* ── WORKFLOW STEPS ────────────────────────────────── */
  .lg-workflow {
    padding: 80px 0 96px;
    position: relative;
  }

  .lg-workflow-label {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--color-text-muted);
    text-align: center;
    margin-bottom: 56px;
  }

  .lg-timeline {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
  }

  .lg-timeline::before {
    content: '';
    position: absolute;
    left: 40px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(
      to bottom,
      var(--color-border) 0%,
      var(--color-primary) 15%,
      var(--color-primary) 85%,
      var(--color-accent) 100%
    );
  }

  .lg-step {
    position: relative;
    padding-left: 100px;
    padding-bottom: 56px;
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .lg-step.lg-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .lg-step:last-child {
    padding-bottom: 0;
  }

  .lg-node {
    position: absolute;
    left: 24px;
    top: 4px;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: var(--color-surface);
    border: 3px solid var(--color-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--font-weight-semibold);
    color: var(--color-primary);
    transition: all 0.4s ease;
  }

  .lg-step.lg-visible .lg-node {
    background: var(--color-primary);
    color: #fff;
    box-shadow: 0 0 0 6px rgba(39, 90, 78, 0.12);
  }

  .lg-step:last-child .lg-node {
    border-color: var(--color-accent);
  }

  .lg-step:last-child.lg-visible .lg-node {
    background: var(--color-accent);
    box-shadow: 0 0 0 6px rgba(200, 161, 90, 0.15);
  }

  .lg-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 32px 36px;
    transition: border-color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
  }

  .lg-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-lg);
    transform: translateX(4px);
  }

  .lg-step:last-child .lg-card {
    border-color: rgba(200, 161, 90, 0.3);
    background: linear-gradient(135deg, rgba(200, 161, 90, 0.04) 0%, var(--color-surface) 100%);
  }

  .lg-step:last-child .lg-card:hover {
    border-color: var(--color-accent);
  }

  .lg-card-header {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 12px;
