    font-family: var(--font-mono);
    font-size: var(--font-size-xl);
    color: var(--color-text-muted);
    transition: transform 0.3s ease;
  }

  .lg-tech details[open] summary::after {
    transform: rotate(45deg);
  }

  .lg-tech summary:hover {
    background: rgba(39, 90, 78, 0.03);
  }

  .lg-tech__body {
    padding: 0 32px 32px;
  }

  .lg-tech__desc {
    font-family: var(--font-sans);
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    margin-bottom: 24px;
  }

  .lg-tech__stack {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .lg-tech__tag {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    color: var(--color-primary);
    background: rgba(39, 90, 78, 0.06);
    border: 1px solid rgba(39, 90, 78, 0.15);
    padding: 6px 14px;
    border-radius: var(--radius-full);
  }

  /* ── RESPONSIVE ────────────────────────────────────── */
  @media (max-width: 760px) {
    .lg-hero { padding: 64px 0 56px; }

    .lg-timeline::before { left: 20px; }
    .lg-node { left: 4px; width: 30px; height: 30px; }
    .lg-step { padding-left: 60px; padding-bottom: 40px; }
    .lg-card { padding: 24px 20px; }

    .lg-trust__grid { grid-template-columns: 1fr; gap: 32px; }

    .lg-next-steps { flex-direction: column; gap: 12px; align-items: center; }

    .lg-email-callout { padding: 32px 24px; }
    .lg-quote-form .form-row--split { grid-template-columns: 1fr; }
    .lg-companies__box { padding: 36px 24px; }

    .lg-pricing-iframe iframe { height: 400px; }
