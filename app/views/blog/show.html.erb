<% content_for :title, "#{@post[:title]} | Ze Lu Sottomayor" %>
<% content_for :meta_description, @post[:meta_description] %>
<% content_for :head do %>
  <script type="application/ld+json">
    <%= {
      "@context" => "https://schema.org",
      "@type" => "BlogPosting",
      "headline" => @post[:title],
      "description" => @post[:meta_description],
      "author" => {
        "@type" => "Person",
        "name" => @post[:author],
        "url" => "https://zelusottomayor.com"
      },
      "datePublished" => @post[:date].iso8601,
      "publisher" => {
        "@type" => "Person",
        "name" => "Ze Lu Sottomayor",
        "url" => "https://zelusottomayor.com"
      },
      "keywords" => @post[:tags].join(", ")
    }.to_json.html_safe %>
  </script>
<% end %>

<article class="py-16 px-4 max-w-3xl mx-auto">
  <header class="mb-10">
    <div class="text-sm text-gray-400 mb-3">
      <%= @post[:date].strftime("%-d %B %Y") %>
      <% if @post[:tags].any? %>
        &nbsp;·&nbsp;
        <%= @post[:tags].first(3).join(" · ") %>
      <% end %>
    </div>
    <h1 class="text-4xl font-bold text-gray-900 leading-tight mb-4"><%= @post[:title] %></h1>
    <% if @post[:meta_description] %>
      <p class="text-xl text-gray-500 leading-relaxed"><%= @post[:meta_description] %></p>
    <% end %>
  </header>

  <div class="prose prose-lg prose-gray max-w-none">
    <%= @post[:content_html] %>
  </div>

  <footer class="mt-16 pt-8 border-t border-gray-100">
    <div class="flex items-center justify-between">
      <%= link_to "← All posts", blog_path, class: "text-blue-600 hover:text-blue-800 font-medium" %>
      <%= link_to "Work with Ze Lu →", book_call_path, class: "text-blue-600 hover:text-blue-800 font-medium" %>
    </div>
  </footer>
</article>
