<% content_for :title, "Blog — AI Automation & B2B Growth | Ze Lu Sottomayor" %>
<% content_for :meta_description, "Insights on AI automation, outbound sales, and building lean B2B operations. Written by Ze Lu Sottomayor, AI automation consultant based in Lisbon." %>

<section class="py-16 px-4 max-w-4xl mx-auto">
  <div class="mb-12">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Blog</h1>
    <p class="text-lg text-gray-600">AI automation, B2B growth, and building things that actually work.</p>
  </div>

  <% if @posts.empty? %>
    <p class="text-gray-500">No posts yet — check back soon.</p>
  <% else %>
    <div class="space-y-10">
      <% @posts.each do |post| %>
        <article class="border-b border-gray-100 pb-10">
          <div class="text-sm text-gray-400 mb-2"><%= post[:date].strftime("%-d %B %Y") %></div>
          <h2 class="text-2xl font-semibold text-gray-900 mb-3">
            <%= link_to post[:title], blog_post_path(post[:slug]), class: "hover:text-blue-600 transition-colors" %>
          </h2>
          <p class="text-gray-600 leading-relaxed mb-4"><%= post[:excerpt] %></p>
          <% if post[:tags].any? %>
            <div class="flex flex-wrap gap-2">
              <% post[:tags].each do |tag| %>
                <span class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded"><%= tag %></span>
              <% end %>
            </div>
          <% end %>
        </article>
      <% end %>
    </div>
  <% end %>
</section>
